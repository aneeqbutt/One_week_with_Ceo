// Mirrors the sync-service DB2 schema exactly.
// listing-site owns a separate Prisma client pointed at the same database.
// It is READ-ONLY by convention — no mutations happen from the website.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          Int       @id @default(autoincrement())
  sourceId    Int       @unique @map("source_id")
  campaignId  String    @map("campaign_id")
  title       String
  description String?
  niche       String?
  platform    String?
  tool        String?
  upworkUrl   String?   @map("upwork_url")
  searchQuery String?   @map("search_query")
  createdAt   DateTime  @map("created_at")
  syncedAt    DateTime  @map("synced_at")

  products Product[]
  blogs    Blog[]
  services Service[]

  @@map("jobs")
}

model Product {
  id          Int      @id @default(autoincrement())
  jobId       Int      @map("job_id")
  sourceId    Int      @unique @map("source_id")
  repoName    String?  @map("repo_name")
  description String?
  readme      String?
  topics      Json     @default("[]")
  createdAt   DateTime @map("created_at")
  syncedAt    DateTime @map("synced_at")
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("products")
}

model Blog {
  id        Int      @id @default(autoincrement())
  jobId     Int      @map("job_id")
  sourceId  Int      @unique @map("source_id")
  title     String?
  content   String?
  createdAt DateTime @map("created_at")
  syncedAt  DateTime @map("synced_at")
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("blogs")
}

model Service {
  id        Int      @id @default(autoincrement())
  jobId     Int      @map("job_id")
  sourceId  Int      @unique @map("source_id")
  title     String?
  content   String?
  createdAt DateTime @map("created_at")
  syncedAt  DateTime @map("synced_at")
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("services")
}

model SyncAuditLog {
  id         Int      @id @default(autoincrement())
  runAt      DateTime @map("run_at")
  tableName  String   @map("table_name")
  rowsSynced Int      @map("rows_synced")
  error      String?
  durationMs Int?     @map("duration_ms")

  @@map("sync_audit_log")
}
