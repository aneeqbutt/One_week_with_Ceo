# ─── DB1 — Source (upwork_jobs) ── READ-ONLY ─────────────────────────────────
# This is the only place DB1 credentials exist. Never share with listing-site.
DB1_HOST=localhost
DB1_PORT=5432
DB1_DATABASE=upwork_jobs
DB1_USER=postgres
DB1_PASSWORD=12345678

# ─── DB2 — Destination (listing_site) ────────────────────────────────────────
DB2_HOST=localhost
DB2_PORT=5432
DB2_DATABASE=listing_site
DB2_USER=postgres
DB2_PASSWORD=12345678

# Prisma uses this URL to manage DB2 schema
DATABASE_URL="postgresql://postgres:12345678@localhost:5432/listing_site?schema=public"

# ─── Sync Service ─────────────────────────────────────────────────────────────
PORT=4000
SYNC_INTERVAL_MS=60000
SYNC_BATCH_SIZE=50
SYNC_MAX_ATTEMPTS=5

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=src/logs
